# Server Configuration
PORT=3000
NODE_ENV=development

# PostgreSQL Configuration (used by Prisma)
DATABASE_URL=postgresql://username:password@localhost:5434/CocoScheme?schema=public
# Docker dev (docker-compose.dev.yml): Postgres se publica en el host como 5434 -> usa localhost:5434
# DATABASE_URL=postgresql://cocoscheme:cocoscheme_dev@localhost:5434/CocoScheme?schema=public

# API Keys (if needed)
# API_KEY=your_api_key

# Allowed browser origins for CORS (comma-separated). Defaults to https://localhost:4321 if unset.
CORS_ORIGIN=http://localhost:4321,https://localhost:4321

# --- AWS S3 (almacenamiento de TODOS los archivos: comprobantes PDF/XML, imágenes
#     internacionales y objetos genéricos vía POST /api/files/upload) ---
# Producción: credenciales IAM/rol; NO definas AWS_S3_ENDPOINT.
# Local con LocalStack (docker-compose.dev.yml publica 4566):
#   AWS_REGION=us-east-1
#   AWS_S3_BUCKET=coco-consulting-local
#   AWS_S3_ENDPOINT=http://localhost:4566
#   AWS_ACCESS_KEY_ID=test
#   AWS_SECRET_ACCESS_KEY=test
# Opcional: AWS_S3_FORCE_PATH_STYLE=false para forzar virtual-hosted (por defecto en endpoint: path-style).
# AWS_REGION=
# AWS_S3_BUCKET=
# AWS_S3_ENDPOINT=

#Keys to be replaced with the keys uploaded to the sharepoint
#For the time-being feel free to add any string with that length
AES_SECRET_KEY=<32characterkey>
JWT_SECRET=<key>
#TEST_TOKEN=<jwt token>
#Example to gen key on development `bun -e "console.log(require('crypto').randomBytes(32).toString('hex'))"'
CHAT_CURSOR_SECRET=superScrete64charKeyForCursorAndUsersMaskingOnChat
CHAT_MESSAGE_SECRET=superScrete64charKeyForChatMessageEncryption

# Pepper para HMAC-SHA256 sobre claves API (api_keys.key_hash). >=16 chars.
# Si no se define, cae a JWT_SECRET. En prod usa un secreto independiente.
API_KEY_HASH_PEPPER=<key>

#Please check the sharepoint folder certificates
#and environment files for the real user and password
MAIL_USER=test.mail@outlook.com
MAIL_PASSWORD=password
# Outlook: MAIL_SMTP_HOST=smtp.office365.com MAIL_SMTP_PORT=587 MAIL_SMTP_SECURE=false
# Gmail (default): smtp.gmail.com:465
# MAIL_SMTP_HOST=smtp.gmail.com
# MAIL_SMTP_PORT=465
# MAIL_FROM=Portal de Viajes <test.mail@outlook.com>

# Currency Exchange API Configuration
# Wise OAuth 2.0 Configuration
WISE_CLIENT_ID=your_wise_client_id_here
WISE_CLIENT_SECRET=your_wise_client_secret_here

# Banxico API Configuration (SieAPIRest token para header Bmx-Token; opcional para tipo de cambio en pólizas USD)
BANXICO_API_KEY=your_banxico_api_key_get_one_here_https://www.banxico.org.mx/SieAPIRest/service/v1/token
# Deshabilitar llamada SF43718 en pólizas (1 = solo CFDI / fallback)
#BANXICO_DISABLE=1

# Export contable SAP: 1 = error si un campo excede longitud BAPI (sin truncar silenciosamente)
#ACCOUNTING_EXPORT_STRICT_LENGTHS=1
#BMX_MOCK_PORT=3002
BMX_API_URL=https://www.banxico.org.mx/SieAPIRest/service/v1

# Wise mTLS Certificate Paths (optional - defaults shown)
WISE_SANDBOX_CERT_PATH=./certs/wise/sandbox-CERTIFICATE.pem
WISE_SANDBOX_KEY_PATH=./certs/wise/sandbox-PRIVATE-KEY.key
WISE_SANDBOX_CA_PATH=./certs/wise/wise-sandbox.pem

WISE_PROD_CERT_PATH=./certs/wise/production-CERTIFICATE.pem
WISE_PROD_KEY_PATH=./certs/wise/production-PRIVATE-KEY.key
WISE_PROD_CA_PATH=./certs/wise/wise-production.pem

# Consulta de estado CFDI (SAT) — WSDL del servicio ConsultaCFDI
# SAT_WSDL_URL=https://consultaqr.facturaelectronica.sat.gob.mx/ConsultaCFDIService.svc?wsdl
# Timeout por peticion SOAP en ms (default 10000)
# SAT_REQUEST_TIMEOUT_MS=10000
SAT_WSDL_URL=https://consultaqr.facturaelectronica.sat.gob.mx/ConsultaCFDIService.svc?wsdl
SAT_REQUEST_TIMEOUT_MS=10_000
#RUN_REAL_SAT_TESTS=0
#SAT_MOCK_PORT=3001

# Prisma triggers (NODE_ENV must be 'test')
PRISMA_DISABLE_TRIGGERS=false

# Web Push Notifications (M3-006) — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_MAILTO=mailto:admin@coconsulting.com

# TF-010 — Vuelos (Duffel sandbox) y fallback mock
# FLIGHT_PROVIDER=mock | duffel
FLIGHT_PROVIDER=mock
# Token sandbox: https://duffel.com — Developers → Access tokens (NO commitear)
# DUFFEL_ACCESS_TOKEN=
# Hospedaje: Duffel Stays requiere Stays habilitado en la cuenta Duffel (si no, el backend usa mock).
# HOTEL_PROVIDER=mock | duffel  (sin definir + FLIGHT_PROVIDER=duffel → intenta Duffel, fallback mock en 403)
# STAYS_SEARCH_RADIUS_KM=10   (1–100 km; Duffel recomienda 5–10 por ciudad)
