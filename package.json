{
  "name": "tc3005b-501-backend",
  "version": "0.1.0",
  "type": "module",
  "description": "API and Database for the conection and the functioning of the trip management system portal developed in course TC3005B by group 501.",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "dev:with-ts-watch": "concurrently -n tsc,api -c blue,green \"bunx tsc -p tsconfig.build.json --watch --preserveWatchOutput\" \"node --watch index.js\"",
    "dummy_db": "bunx prisma db push --force-reset && node prisma/seed.js dev",
    "empty_db": "bunx prisma db push --force-reset && node prisma/seed.js",
    "migrate": "bunx prisma migrate dev",
    "generate": "bunx prisma generate",
    "studio": "bunx prisma studio",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "build:ts": "bunx tsc -p tsconfig.build.json",
    "typecheck:new": "bunx tsc -p tsconfig.src-ts.json --noEmit",
    "build": "node scripts/verify-build.mjs",
    "test": "NODE_OPTIONS='--experimental-vm-modules' bunx jest --coverage --testPathIgnorePatterns='/node_modules|\\.e2e\\.test\\.'",
    "test:watch": "NODE_OPTIONS='--experimental-vm-modules' bunx jest --watch --testPathIgnorePatterns='/node_modules|\\.e2e\\.test\\.'",
    "docker:test": "docker compose -f docker-compose.dev.yml exec -T -e NODE_OPTIONS=--experimental-vm-modules backend bunx jest --coverage --testPathIgnorePatterns='/node_modules|\\.e2e\\.test\\.'",
    "docker:test:watch": "docker compose -f docker-compose.dev.yml exec -e NODE_OPTIONS=--experimental-vm-modules backend bunx jest --watch --testPathIgnorePatterns='/node_modules|\\.e2e\\.test\\.'",
    "docker:prisma": "docker compose -f docker-compose.dev.yml exec -T backend bunx prisma",
    "test:e2e": "NODE_OPTIONS='--experimental-vm-modules' bunx jest tests --verbose --detectOpenHandles --testTimeout=60000 --testMatch='**/*.e2e.test*.{js,ts}'",
    "test:e2e:watch": "NODE_OPTIONS='--experimental-vm-modules' bunx jest tests --watch --verbose --detectOpenHandles --testTimeout=60000 --testMatch='**/*.e2e.test*.{js,ts}'",
    "test:all": "NODE_OPTIONS='--experimental-vm-modules' bunx jest tests --verbose --detectOpenHandles --testTimeout=60000",
    "docker:dev": "docker compose -f docker-compose.dev.yml up --watch",
    "docker:dev:build": "docker compose -f docker-compose.dev.yml up --build --watch",
    "docker:dev:down": "docker compose -f docker-compose.dev.yml down",
    "docker:dev:clean": "docker compose -f docker-compose.dev.yml down -v",
    "docker:data:reset": "docker compose -f docker-compose.dev.yml exec -T backend sh -c 'bunx prisma db push --force-reset && node prisma/seed.js dev'",
    "docker:permissions:sync": "docker compose -f docker-compose.dev.yml exec -T backend node prisma/seed.js",
    "seed": "node prisma/seed-orgs.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yourusername/TC3005B.501-Backend.git"
  },
  "keywords": [
    "travel",
    "management",
    "system",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1017.0",
    "@aws-sdk/s3-request-presigner": "^3.1017.0",
    "@prisma/client": "^6.16.0",
    "axios": "^1.15.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csurf": "^1.11.0",
    "csv-parse": "^5.6.0",
    "dotenv": "^16.4.7",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.2.1",
    "fast-xml-parser": "^5.5.11",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.2",
    "mongo-sanitize": "^1.1.0",
    "mongodb": "^5.0.0",
    "multer": "^2.0.1",
    "nodemailer": "^7.0.3",
    "soap": "^1.8.0",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@jest/globals": "^30.3.0",
    "@swc/core": "^1.15.24",
    "@swc/jest": "^0.2.39",
    "concurrently": "^9.2.1",
    "eslint": "^9.0.0",
    "eslint-plugin-jsdoc": "^50.0.0",
    "jest": "^30.3.0",
    "prisma": "^6.16.0",
    "supertest": "^7.2.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {
      "^.+\\.ts$": "@swc/jest"
    },
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "middleware/authMiddleware.js",
      "middleware/authErrors.js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/"
    ]
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "trustedDependencies": [
    "@prisma/client",
    "@prisma/engines",
    "bcrypt",
    "prisma",
    "unrs-resolver"
  ]
}
