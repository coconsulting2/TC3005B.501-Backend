    {
      "name": "Download",
      "description": "Escenarios para GET /api/files/:id/download",
      "item": [
        {
          "name": "TC-S3-009 | Download - Obtener URL prefirmada (Happy Path)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code es 200', function () {",
