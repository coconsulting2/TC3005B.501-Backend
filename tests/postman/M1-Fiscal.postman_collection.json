									"    const schema = {",
									"        type: 'object',",
									"        required: ['polizas'],",
									"        properties: {",
									"            polizas: {",
									"                type: 'array',",
									"                items: { type: 'object' }",
									"            }",
									"        }",
									"    };",
									"    pm.response.to.have.jsonSchema(schema);",
									"});"
								]
