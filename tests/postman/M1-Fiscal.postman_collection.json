					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status code is 200', () => {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response has polizas array', () => {",
									"    const json = pm.response.json();",
									"    pm.expect(json).to.have.property('polizas');",
									"    pm.expect(json.polizas).to.be.an('array');",
									"});",
									"",
									"pm.test('Missing date params returns 400', () => {",
									"    // This test documents expected behavior when from/to are missing.",
									"    // Remove query params and re-run to verify 400 response.",
