									"});"
								]
							}
						}
					]
				}
			]
		},
		{
			"name": "Viajes",
			"description": "Travel trip endpoints — consolidated accounting summary by tramo.",
			"item": [
				{
					"name": "Get resumen tramos",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{jwt_token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/viajes/{{viaje_id}}/resumen-tramos",
							"host": ["{{base_url}}"],
							"path": ["api", "viajes", "{{viaje_id}}", "resumen-tramos"]
						},
						"description": "Returns a consolidated accounting summary of comprobantes grouped by tramo for a given viaje.\n\nRoles: Solicitante, N1, N2, Cuentas por pagar."
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status code is 200', () => {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response has viaje_id', () => {",
									"    const json = pm.response.json();",
									"    pm.expect(json).to.have.property('viaje_id');",
									"});",
									"",
									"pm.test('Response has tramos array', () => {",
									"    const json = pm.response.json();",
									"    pm.expect(json).to.have.property('tramos');",
									"    pm.expect(json.tramos).to.be.an('array');",
									"});",
									"",
									"pm.test('Response has total_general', () => {",
									"    const json = pm.response.json();",
									"    pm.expect(json).to.have.property('total_general');",
									"});",
									"",
									"pm.test('Schema validation', () => {",
									"    const schema = {",
									"        type: 'object',",
									"        required: ['viaje_id', 'tramos', 'total_general'],",
									"        properties: {",
									"            viaje_id: { type: 'number' },",
									"            tramos: {",
									"                type: 'array',",
									"                items: {",
									"                    type: 'object',",
									"                    required: ['tramo_id'],",
									"                    properties: {",
									"                        tramo_id: { type: 'number' },",
									"                        comprobantes: { type: 'array' },",
									"                        total_tramo: { type: 'number' }",
									"                    }",
									"                }",
									"            },",
									"            total_general: { type: 'number' }",
									"        }",
									"    };",
									"    pm.response.to.have.jsonSchema(schema);",
									"});"
								]
							}
						}
					]
				}
			]
		},
		{
			"name": "Accounting Export",
