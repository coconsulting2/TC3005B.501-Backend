{
	"info": {
		"_postman_id": "m2-authorization-collection",
		"name": "M2-Authorization",
		"description": "Postman collection for Module 2 (Authorization & Workflow) endpoints.\n\nCovers:\n- Permissions catalog CRUD (/api/admin/permissions*)\n- Permission groups CRUD and assignment (/api/admin/permission-groups*)\n- Role and user permission assignment (/api/admin/roles/:roleId/..., /api/admin/users/:userId/...)\n- Approval workflow end-to-end: create travel request (Solicitante) → authorize N1 → authorize N2 → verify final status\n- Negative scenarios: decline without comment (expects 400), admin route as Solicitante (expects 403)\n\nTokens:\n- {{admin_token}} for /api/admin/* requests (Administrador)\n- {{requester_token}} for travel request creation and reads (Solicitante)\n- {{approver_token}} for first-level authorization (N1)\n- {{approver_n2_token}} for second-level authorization (N2)\n\nThe collection-level pre-request script logs in all four roles on first run, fetches the CSRF token, and caches everything in collection variables. Subsequent requests reuse the cached tokens.\n\nTask: NT-016",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{ "key": "base_url", "value": "https://localhost:3000", "type": "string" },
		{ "key": "csrf_token", "value": "", "type": "string" },
		{ "key": "admin_token", "value": "", "type": "string" },
		{ "key": "requester_token", "value": "", "type": "string" },
		{ "key": "approver_token", "value": "", "type": "string" },
		{ "key": "approver_n2_token", "value": "", "type": "string" },
		{ "key": "admin_username", "value": "admin", "type": "string" },
		{ "key": "admin_password", "value": "admin123", "type": "string" },
		{ "key": "requester_username", "value": "andres.gomez", "type": "string" },
		{ "key": "requester_password", "value": "andres123", "type": "string" },
		{ "key": "n1_username", "value": "laura.flores", "type": "string" },
		{ "key": "n1_password", "value": "laura321", "type": "string" },
		{ "key": "n2_username", "value": "diego.hernandez", "type": "string" },
		{ "key": "n2_password", "value": "diego654", "type": "string" },
		{ "key": "requester_user_id", "value": "", "type": "string" },
		{ "key": "n1_user_id", "value": "", "type": "string" },
		{ "key": "n2_user_id", "value": "", "type": "string" },
		{ "key": "permission_id", "value": "", "type": "string" },
		{ "key": "group_id", "value": "", "type": "string" },
		{ "key": "request_id", "value": "", "type": "string" },
		{ "key": "role_id_solicitante", "value": "1", "type": "string" }
	],
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Skip auth bootstrapping for the explicit Auth folder requests — they manage their own tokens.",
					"const url = pm.request.url.toString();",
					"if (url.includes('/api/user/login') || url.includes('/api/user/csrf-token')) { return; }",
					"",
					"const baseUrl = pm.collectionVariables.get('base_url');",
					"",
					"const loginAs = (tokenVar, userIdVar, usernameVar, passwordVar, callback) => {",
					"    const existing = pm.collectionVariables.get(tokenVar);",
					"    if (existing) { return callback(); }",
					"    const username = pm.collectionVariables.get(usernameVar);",
					"    const password = pm.collectionVariables.get(passwordVar);",
					"    if (!username || !password) {",
					"        console.warn('Missing credentials for ' + tokenVar);",
					"        return callback();",
					"    }",
					"    pm.sendRequest({",
					"        url: baseUrl + '/api/user/login',",
					"        method: 'POST',",
					"        header: [{ key: 'Content-Type', value: 'application/json' }],",
					"        body: { mode: 'raw', raw: JSON.stringify({ username, password }) }",
					"    }, (err, res) => {",
					"        if (err || res.code !== 200) {",
					"            console.error('Login failed for ' + tokenVar + ':', err || res.code);",
					"            return callback();",
					"        }",
					"        const data = res.json();",
					"        pm.collectionVariables.set(tokenVar, data.token);",
					"        if (userIdVar && data.user_id) {",
					"            pm.collectionVariables.set(userIdVar, String(data.user_id));",
					"        }",
					"        callback();",
					"    });",
					"};",
					"",
					"const fetchCsrf = (callback) => {",
					"    if (pm.collectionVariables.get('csrf_token')) { return callback(); }",
					"    pm.sendRequest({",
					"        url: baseUrl + '/api/user/csrf-token',",
					"        method: 'GET'",
					"    }, (err, res) => {",
					"        if (!err && res && res.code === 200) {",
					"            pm.collectionVariables.set('csrf_token', res.json().csrfToken);",
					"        }",
					"        callback();",
					"    });",
					"};",
					"",
					"// Chain: admin → requester → N1 → N2 → CSRF",
					"loginAs('admin_token', null, 'admin_username', 'admin_password', () => {",
					"    loginAs('requester_token', 'requester_user_id', 'requester_username', 'requester_password', () => {",
					"        loginAs('approver_token', 'n1_user_id', 'n1_username', 'n1_password', () => {",
					"            loginAs('approver_n2_token', 'n2_user_id', 'n2_username', 'n2_password', () => {",
					"                fetchCsrf(() => {});",
					"            });",
					"        });",
					"    });",
					"});"
				]
			}
		}
	],
