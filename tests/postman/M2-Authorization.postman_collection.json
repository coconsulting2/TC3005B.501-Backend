		{
			"name": "Workflow — Happy path",
			"description": "End-to-end approval flow: Solicitante creates a travel request, N1 approves, N2 approves, final status verified via GET.",
			"item": [
				{
					"name": "Create travel request (Solicitante)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{requester_token}}" },
							{ "key": "x-csrf-token", "value": "{{csrf_token}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"router_index\": 0,\n    \"notes\": \"NT-016 Postman e2e test request\",\n    \"requested_fee\": 1500.00,\n    \"imposed_fee\": 1500.00,\n    \"origin_country_name\": \"Mexico\",\n    \"origin_city_name\": \"Monterrey\",\n    \"destination_country_name\": \"Mexico\",\n    \"destination_city_name\": \"Mexico City\",\n    \"beginning_date\": \"2026-05-01\",\n    \"beginning_time\": \"08:00\",\n    \"ending_date\": \"2026-05-03\",\n    \"ending_time\": \"18:00\",\n    \"plane_needed\": true,\n    \"hotel_needed\": true,\n    \"additionalRoutes\": []\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/applicant/create-travel-request/{{requester_user_id}}",
							"host": ["{{base_url}}"],
							"path": ["api", "applicant", "create-travel-request", "{{requester_user_id}}"]
						},
						"description": "Creates a travel request as the Solicitante. Requires travel_request:create. Stores the resulting request_id."
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status is 200 or 201', () => pm.expect([200, 201]).to.include(pm.response.code));",
									"pm.test('Stores request_id', () => {",
									"    const json = pm.response.json();",
									"    const id = json.request_id || json.requestId || (json.data && (json.data.request_id || json.data.requestId));",
									"    pm.expect(id, 'request_id missing in response').to.exist;",
									"    pm.collectionVariables.set('request_id', String(id));",
									"});"
								]
							}
						}
					]
				},
				{
					"name": "Approve N1",
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{approver_token}}" },
							{ "key": "x-csrf-token", "value": "{{csrf_token}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": { "mode": "raw", "raw": "{}" },
						"url": {
							"raw": "{{base_url}}/api/authorizer/authorize-travel-request/{{request_id}}/{{n1_user_id}}",
							"host": ["{{base_url}}"],
							"path": ["api", "authorizer", "authorize-travel-request", "{{request_id}}", "{{n1_user_id}}"]
						},
						"description": "First-level approval (N1). Requires travel_request:authorize. Expects new_status to advance to 'Segunda Revisión'."
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status 200', () => pm.response.to.have.status(200));",
									"pm.test('Advanced to second review', () => {",
									"    const json = pm.response.json();",
									"    pm.expect(json).to.have.property('new_status');",
									"    pm.expect(json.new_status).to.match(/Segunda Revisión|Cotización del Viaje/i);",
									"});"
								]
							}
						}
					]
				},
				{
					"name": "Approve N2",
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{approver_n2_token}}" },
							{ "key": "x-csrf-token", "value": "{{csrf_token}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": { "mode": "raw", "raw": "{}" },
						"url": {
							"raw": "{{base_url}}/api/authorizer/authorize-travel-request/{{request_id}}/{{n2_user_id}}",
							"host": ["{{base_url}}"],
							"path": ["api", "authorizer", "authorize-travel-request", "{{request_id}}", "{{n2_user_id}}"]
						},
						"description": "Second-level approval (N2). Expects new_status to land on 'Cotización del Viaje' (or equivalent next phase)."
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
