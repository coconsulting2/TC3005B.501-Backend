	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Skip auth bootstrapping for explicit login / csrf endpoints.",
					"const url = pm.request.url.toString();",
					"if (url.includes('/api/user/login') || url.includes('/api/user/csrf-token')) { return; }",
					"",
					"const baseUrl = pm.collectionVariables.get('base_url');",
					"",
					"const loginAs = (tokenVar, usernameVar, passwordVar, callback) => {",
					"    const existing = pm.collectionVariables.get(tokenVar);",
					"    if (existing) { return callback(); }",
					"    const username = pm.collectionVariables.get(usernameVar);",
					"    const password = pm.collectionVariables.get(passwordVar);",
					"    if (!username || !password) {",
					"        console.warn('Missing credentials for ' + tokenVar);",
					"        return callback();",
					"    }",
					"    pm.sendRequest({",
					"        url: baseUrl + '/api/user/login',",
					"        method: 'POST',",
					"        header: [{ key: 'Content-Type', value: 'application/json' }],",
					"        body: { mode: 'raw', raw: JSON.stringify({ username, password }) }",
					"    }, (err, res) => {",
					"        if (err || res.code !== 200) {",
					"            console.error('Login failed for ' + tokenVar + ':', err || res.code);",
					"            return callback();",
					"        }",
					"        const data = res.json();",
					"        pm.collectionVariables.set(tokenVar, data.token);",
					"        callback();",
					"    });",
					"};",
					"",
					"const fetchCsrf = (callback) => {",
					"    if (pm.collectionVariables.get('csrf_token')) { return callback(); }",
					"    pm.sendRequest({",
					"        url: baseUrl + '/api/user/csrf-token',",
					"        method: 'GET'",
					"    }, (err, res) => {",
					"        if (!err && res && res.code === 200) {",
					"            pm.collectionVariables.set('csrf_token', res.json().csrfToken);",
					"        }",
					"        callback();",
					"    });",
					"};",
					"",
					"loginAs('admin_token', 'admin_username', 'admin_password', () => {",
					"    loginAs('cxp_token', 'cxp_username', 'cxp_password', () => {",
					"        fetchCsrf(() => {});",
					"    });",
					"});"
				]
			}
		}
	],
