		{
			"name": "API Keys lifecycle",
			"description": "Generar -> consumir -> listar -> auditar logs -> revocar -> verificar 401. Prefijo real /api/keys (NO /api/api-keys).",
			"item": [
				{
					"name": "Generate key",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{admin_token}}"
							},
							{
								"key": "x-csrf-token",
								"value": "{{csrf_token}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "X-Organization-Id",
								"value": "{{target_org_id}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"org_id\": \"{{target_org_id}}\",\n    \"name\": \"qa-m3-key-{{$timestamp}}\",\n    \"scope\": { \"permissions\": [\"accounting:export\"] },\n    \"expires_at\": \"{{key_expires_at}}\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/keys/generate",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"keys",
								"generate"
							]
						},
						"description": "Genera una API key con permiso accounting:export para la org 101. Captura id y secret en variables de coleccion."
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status 201', () => pm.response.to.have.status(201));",
									"pm.test('Response has id and key (secret)', () => {",
									"    const json = pm.response.json();",
									"    pm.expect(json).to.have.property('id');",
									"    pm.expect(json).to.have.property('key');",
									"    pm.expect(json.key).to.match(/^cck_[a-f0-9]+$/);",
									"    pm.collectionVariables.set('api_key_id', String(json.id));",
									"    pm.collectionVariables.set('api_key_secret', json.key);",
									"});",
									"pm.test('Active true and scope echoed', () => {",
									"    const json = pm.response.json();",
									"    pm.expect(json.active).to.eql(true);",
									"    pm.expect(json.scope.permissions).to.include('accounting:export');",
									"});"
								]
							}
						}
					]
				},
